---
title: BLKB Server Internal Flow
---
stateDiagram-v2
    state "GLib Main Loop" as GLIB
    [*] --> Setup

    state Setup {
        [*] --> setup_bt_device
        setup_bt_device --> register_agent
        register_agent --> register_sdp
        register_sdp --> set_class
        set_class --> start_listening
    }

    start_listening --> Waiting

    state Waiting {
        [*] --> listen_control
        [*] --> listen_interrupt
        [*] --> listen_socket
    }

    state HID_Connected {
        [*] --> control_accepted
        control_accepted --> interrupt_accepted
        interrupt_accepted --> Ready

        state "Command Queue" as CQ {
            [*] --> Idle
            Idle --> Processing : command arrives
            Processing --> TypeSeq : "type"
            Processing --> SingleKey : "key / mod"
            Processing --> WaitTimer : "delay"
            TypeSeq --> Idle : OK sent
            SingleKey --> Idle : OK sent
            WaitTimer --> Idle : OK sent
        }

        state "Type Sequence" as TS {
            [*] --> KeyDown
            KeyDown --> KeyUp : 50ms
            KeyUp --> NextOrDone : 50ms
            NextOrDone --> KeyDown : more chars
            NextOrDone --> [*] : last char
        }
    }

    Waiting --> HID_Connected : incoming L2CAP PSM 17
    Waiting --> HID_Connected : incoming L2CAP PSM 19
    listen_socket --> CQ : "type hello\\n"
    control_accepted --> HIDP_Handler : HIDP messages
    HIDP_Handler --> Ready
