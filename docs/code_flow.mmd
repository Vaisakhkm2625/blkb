---
title: BLKB Server Internal Flow
---
stateDiagram-v2
    state "GLib Main Loop" as GLIB {
        [*] --> Setup

        state Setup {
            setup_bt_device() --> register_agent()
            register_agent() --> register_sdp_record()
            register_sdp_record() --> hciconfig_class
            hciconfig_class --> StartListening
        }

        state StartListening {
            listen_psm_17 --> listen_psm_19
            listen_psm_19 --> listen_unix_socket
            listen_unix_socket --> Waiting
        }

        state Waiting {
            Waiting --> SDP_Arrives : incoming L2CAP PSM 1
            Waiting --> Control_Arrives : incoming L2CAP PSM 17
            Waiting --> Interrupt_Arrives : incoming L2CAP PSM 19
            Waiting --> ClientCmd : Unix socket data
            Waiting --> Pairing_Request : HCI event
        }

        state HID_Connected {
            [*] --> BothChannels

            state BothChannels {
                Control_Channel --> Interrupt_Channel
                Interrupt_Channel --> Ready
            }

            state Command_Queue {
                [*] --> Idle
                Idle --> Processing : command queued
                Processing --> Processing : type_next() / type_up()
                Processing --> Idle : OK sent
            }

            state Type_Sequence {
                [*] --> KeyDown
                KeyDown --> KeyUp : 50ms
                KeyUp --> KeyDown : 50ms (next char)
                KeyUp --> Done : last char
                Done --> [*]
            }

            ClientCmd --> Command_Queue : parse "type/ key/ mod/ delay"
            Command_Queue --> Type_Sequence : "type"
            Command_Queue --> SingleKey : "key" or "mod"
            Command_Queue --> WaitTimer : "delay"

            Control_Arrives --> HIDP_Handler
        }

        Pairing_Request --> AgentHandler
    }
